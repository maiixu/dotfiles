#!/usr/bin/env python3
"""Toggle Claude Code between Claude Pro (claude.ai subscription) and AWS Bedrock."""

import json
import sys
import os

SETTINGS_FILE = os.path.expanduser("~/.claude/settings.json")

BEDROCK_ENV = {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_PROFILE": "bedrock-claude",
    "AWS_REGION": "us-west-2",
}
BEDROCK_MODEL = "us.anthropic.claude-sonnet-4-6[1m]"
PRO_MODEL = "claude-sonnet-4-6"


def load():
    with open(SETTINGS_FILE) as f:
        return json.load(f)


def save(settings):
    with open(SETTINGS_FILE, "w") as f:
        json.dump(settings, f, indent=2)
        f.write("\n")


def is_bedrock(settings):
    return settings.get("env", {}).get("CLAUDE_CODE_USE_BEDROCK") == "1"


def to_bedrock(settings):
    settings.setdefault("env", {}).update(BEDROCK_ENV)
    settings["model"] = BEDROCK_MODEL


def to_pro(settings):
    env = settings.get("env", {})
    for k in BEDROCK_ENV:
        env.pop(k, None)
    settings["model"] = PRO_MODEL


def print_status(settings):
    if is_bedrock(settings):
        provider = "api      (AWS Bedrock, profile: bedrock-claude)"
    else:
        provider = "pro      (Claude.ai subscription)"
    print(f"provider : {provider}")
    print(f"model    : {settings.get('model', '(default)')}")
    print()
    print("Restart Claude Code for changes to take effect.")


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else "status"

    settings = load()

    if cmd == "status":
        print_status(settings)

    elif cmd == "pro":
        if not is_bedrock(settings):
            print("Already on Pro.")
            return
        to_pro(settings)
        save(settings)
        print("Switched to Claude Pro.")
        print("Restart Claude Code to apply.")

    elif cmd == "api":
        if is_bedrock(settings):
            print("Already on Bedrock.")
            return
        to_bedrock(settings)
        save(settings)
        print("Switched to AWS Bedrock.")
        print("Restart Claude Code to apply.")

    elif cmd == "toggle":
        if is_bedrock(settings):
            to_pro(settings)
            print("Switched to Claude Pro.")
        else:
            to_bedrock(settings)
            print("Switched to AWS Bedrock.")
        save(settings)
        print("Restart Claude Code to apply.")

    else:
        print(f"Usage: claude-switch [status|pro|api|toggle]")
        sys.exit(1)


if __name__ == "__main__":
    main()
