{
  "env": {},
  "model": "claude-sonnet-4-6",
  "language": "chinese",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/code/dotfiles && git pull --ff-only -q 2>/dev/null; cd ~/notes && git pull --ff-only -q 2>/dev/null",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/maixu/.claude/hooks/block-dangerous-commands.sh"
          }
        ]
      }
    ],
    "PostToolUse": []
  },
  "enabledPlugins": {
    "ralph-skills@ralph-marketplace": true
  },
  "extraKnownMarketplaces": {
    "ralph-marketplace": {
      "source": {
        "source": "github",
        "repo": "snarktank/ralph"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}