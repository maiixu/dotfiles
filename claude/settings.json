{
  "env": {},
  "model": "claude-sonnet-4-6",
  "language": "chinese",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/maixu/.claude/hooks/check-output-language.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/maixu/.claude/hooks/block-dangerous-commands.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ralph-skills@ralph-marketplace": true
  },
  "extraKnownMarketplaces": {
    "ralph-marketplace": {
      "source": {
        "source": "github",
        "repo": "snarktank/ralph"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
